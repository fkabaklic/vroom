{
  "name": "vroom",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "start": "node ./bin/www",
    "test-db": "node ./scripts/test-db.js",
    "init-db": "node ./scripts/init-db.js",
    "seed-vehicles": "node ./scripts/seed-vehicles.js",
    "build:css": "tailwindcss -i ./src/input.css -o ./public/stylesheets/tailwind.css --minify",
    "watch:css": "tailwindcss -i ./src/input.css -o ./public/stylesheets/tailwind.css --watch",
    "build": "npm install && npm run build:css",
    "vercel-build": "npm install --include=dev && npm run build:css"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "~1.4.4",
    "debug": "~2.6.9",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.9",
    "express": "^4.19.2",
    "express-ejs-layouts": "^2.5.1",
    "express-session": "^1.18.0",
    "http-errors": "~1.6.3",
    "mariadb": "^3.3.0",
    "morgan": "^1.11.0"
  },
  "engines": {
    "node": "22.x"
  },
  "type": "commonjs",
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.2",
    "tailwindcss": "^4.3.2"
  }
}
