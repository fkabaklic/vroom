<section class="border-b border-vroom-line bg-white">
  <div class="mx-auto max-w-7xl px-4 py-14 sm:px-6 lg:px-8">
    <h1 class="text-3xl font-bold text-vroom-ink sm:text-4xl">Available Cars</h1>
    <p class="mt-2 text-vroom-muted">Browse our complete collection of vehicles</p>
  </div>
</section>

<section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
  <div class="mb-8 flex items-end justify-between gap-4">
    <div>
      <h2 class="text-2xl font-bold text-vroom-ink">All Vehicles</h2>
      <p class="mt-1 text-sm text-vroom-muted">Choose from our complete fleet</p>
    </div>
  </div>

  <% if (allrecs && allrecs.length > 0) { %>
    <div class="grid gap-6 sm:grid-cols-2 xl:grid-cols-3">
      <% allrecs.forEach((vehicle) => { %>
        <%- include('partials/vehicle-card', { vehicle: vehicle, showAddToCart: true }) %>
      <% }); %>
    </div>
  <% } else { %>
    <div class="rounded-2xl border border-dashed border-vroom-line bg-white px-6 py-16 text-center">
      <i class="fas fa-car-side text-4xl text-vroom-muted"></i>
      <p class="mt-4 text-lg font-medium text-vroom-ink">No vehicles available at the moment.</p>
      <a href="/" class="btn-primary mt-6">Return Home</a>
    </div>
  <% } %>
</section>
