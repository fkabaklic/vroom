<%
  const days = parseInt(vehicle.duration, 10) || 3;
  const daily = Number(vehicle.daily_fee) || 0;
  const total = Math.round(daily * days);
  const trips = 20 + (Number(vehicle.vehicle_id) || 1) * 7;
%>
<div class="vehicle-card group">
  <a href="/vehicle/<%= vehicle.vehicle_id %>/show" class="block">
    <div class="relative aspect-[4/3] overflow-hidden rounded-2xl bg-neutral-100">
      <img
        src="/images/<%= vehicle.prodimage %>"
        alt="<%= vehicle.description %>"
        class="h-full w-full object-cover transition duration-500 group-hover:scale-[1.03]"
      >
      <span class="absolute right-3 top-3 flex h-8 w-8 items-center justify-center rounded-full bg-white/95 text-vroom-ink shadow-sm backdrop-blur transition group-hover:bg-white">
        <i class="far fa-heart text-sm"></i>
      </span>
      <% if (vehicle.featured) { %>
        <span class="absolute left-3 top-3 rounded-full bg-white/95 px-2.5 py-1 text-[11px] font-semibold text-vroom-ink shadow-sm backdrop-blur">
          Featured
        </span>
      <% } %>
    </div>

    <div class="mt-3 space-y-1 px-0.5">
      <h3 class="truncate text-[15px] font-semibold leading-snug text-vroom-ink"><%= vehicle.description %></h3>
      <p class="text-sm text-vroom-muted">
        <%= vehicle.vehicle_type %> · 5.0 <i class="fas fa-star text-[10px]"></i> (<%= trips %>)
      </p>
      <p class="pt-0.5 text-[15px]">
        <span class="font-bold text-vroom-ink">$<%= daily.toFixed(0) %>/day</span>
        <span class="text-vroom-muted">$<%= total %> total</span>
      </p>
    </div>
  </a>

  <% if (typeof showAddToCart !== 'undefined' && showAddToCart) { %>
    <form action="/catalog/add" method="post" class="vehicle-actions mt-3">
      <input type="hidden" name="vehicle_id" value="<%= vehicle.vehicle_id %>">
      <button type="submit" class="btn-secondary w-full text-sm">
        <i class="fas fa-shopping-cart"></i> Add to cart
      </button>
    </form>
  <% } %>
</div>
