<% if (allrecs.length > 0) {%>
    <table>
        <tr>
            <th>Vehicle ID</th>
            <th>Product Image</th>
            <th>Description</th>
            <th>Duration</th>
            <th>Vehicle Type</th>
            <th>Daily Fee</th>
            <th>Renter ID</th>
            <th>Host ID</th>
            <th>Review ID</th>
            <th>Status</th>
            <th>Featured</th>
        </tr>
      <% allrecs.forEach((recref, index) => { %>
        <tr>
            <td align="center"><%= recref.vehicle_id %></td>
            <td align="center"><img src="/images/<%= recref.prodimage %>" style="width: 100px;"></td>
            <td align="right"><%= recref.description %></td>
            <td align="right"><%= recref.duration %></td>
            <td align="right"><%= recref.vehicle_type %></td>
            <td align="right"><%= Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format (recref.daily_fee) %></td>
            <td align="center"><%= recref.renter_id %></td>
            <td align="center"><%= recref.host_id %></td>
            <td align="center"><%= recref.review_id %></td>
            <td align="center"><%= recref.status %></td>
            <td align="center"><%= recref.featured %></td>
            <td><button class="btn3"><a href='/vehicle/<%= recref.vehicle_id %>/show'> Details</a></button></td>
            <td><button class="btn3"><a href='/vehicle/<%= recref.vehicle_id %>/edit'>Edit</a></button></td>
            <td><button class="btn3"><a href='/vehicle/<%= recref.vehicle_id %>/delete' onclick="return confirm('Are you sure you want to delete this record?');">Delete</a></button></td>
            </tr>
    <% }); %>
    </table>
    <% } else { %>
        <p>Not Records Available</p>
    <% } %>
<div class="b">
<button class="btn2"><a href='/vehicle/addrecord'><i class="fa-solid fa-plus"></i></a></button>
</div>