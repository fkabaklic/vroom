<section class="mx-auto max-w-6xl px-4 py-10 sm:px-6 lg:px-8">
  <div class="grid gap-8 lg:grid-cols-2">
    <div class="overflow-hidden rounded-2xl border border-vroom-line bg-white shadow-sm">
      <img src="/images/<%= onerec.prodimage %>" alt="<%= onerec.description %>" class="aspect-[4/3] w-full object-cover">
    </div>

    <div class="space-y-6">
      <div>
        <div class="flex flex-wrap items-center gap-2">
          <span class="status-badge <%= onerec.status.toLowerCase() %>"><%= onerec.status %></span>
          <% if (onerec.featured) { %>
            <span class="inline-flex items-center gap-1 rounded-full bg-amber-100 px-3 py-1 text-xs font-semibold text-amber-700">
              <i class="fas fa-star"></i> Featured
            </span>
          <% } %>
        </div>
        <h1 class="mt-4 text-3xl font-bold text-vroom-ink sm:text-4xl"><%= onerec.description %></h1>
      </div>

      <div class="rounded-2xl border border-vroom-line bg-vroom-canvas p-5">
        <span class="text-4xl font-bold text-vroom-ink">$<%= onerec.daily_fee %></span>
        <span class="ml-2 text-vroom-muted">per day</span>
      </div>

      <div class="grid gap-3 sm:grid-cols-2">
        <div class="flex items-center gap-3 rounded-xl border border-vroom-line bg-white p-4">
          <i class="fas fa-car text-vroom-accent"></i>
          <div>
            <p class="text-xs text-vroom-muted">Vehicle Type</p>
            <p class="font-semibold"><%= onerec.vehicle_type %></p>
          </div>
        </div>
        <div class="flex items-center gap-3 rounded-xl border border-vroom-line bg-white p-4">
          <i class="fas fa-clock text-vroom-accent"></i>
          <div>
            <p class="text-xs text-vroom-muted">Duration</p>
            <p class="font-semibold"><%= onerec.duration %></p>
          </div>
        </div>
        <div class="flex items-center gap-3 rounded-xl border border-vroom-line bg-white p-4">
          <i class="fas fa-user text-vroom-accent"></i>
          <div>
            <p class="text-xs text-vroom-muted">Host ID</p>
            <p class="font-semibold"><%= onerec.host_id %></p>
          </div>
        </div>
        <div class="flex items-center gap-3 rounded-xl border border-vroom-line bg-white p-4">
          <i class="fas fa-id-card text-vroom-accent"></i>
          <div>
            <p class="text-xs text-vroom-muted">Vehicle ID</p>
            <p class="font-semibold"><%= onerec.vehicle_id %></p>
          </div>
        </div>
      </div>

      <div class="space-y-3">
        <form action="/catalog/add" method="post">
          <input type="hidden" name="vehicle_id" value="<%= onerec.vehicle_id %>">
          <button type="submit" class="btn-primary btn-block">
            <i class="fas fa-calendar-check"></i> Book Now
          </button>
        </form>
        <a href="/catalog" class="btn-secondary btn-block">
          <i class="fas fa-arrow-left"></i> Back to Catalog
        </a>
      </div>
    </div>
  </div>
</section>
