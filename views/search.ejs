<section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
  <div class="mb-8">
    <h2 class="text-3xl font-bold text-vroom-ink">Search Results</h2>
    <p class="mt-2 text-vroom-muted">
      Found <%= allrecs.length %> vehicle<%= allrecs.length !== 1 ? 's' : '' %> matching your search
    </p>
    <% if (locals.searchcriteria) { %>
      <div class="mt-4 inline-flex flex-wrap items-center gap-3 rounded-xl border border-vroom-line bg-white px-4 py-3 text-sm">
        <i class="fas fa-search text-vroom-accent"></i>
        <span>Searching for: "<strong><%= searchcriteria %></strong>"</span>
        <a href="/catalog" class="btn-secondary py-1.5 text-xs">
          <i class="fas fa-times"></i> Clear
        </a>
      </div>
    <% } %>
  </div>

  <% if (allrecs && allrecs.length > 0) { %>
    <div class="grid gap-6 sm:grid-cols-2 xl:grid-cols-3">
      <% allrecs.forEach((vehicle) => { %>
        <%- include('partials/vehicle-card', { vehicle: vehicle, showAddToCart: true }) %>
      <% }); %>
    </div>
  <% } else { %>
    <div class="rounded-2xl border border-dashed border-vroom-line bg-white px-6 py-16 text-center">
      <i class="fas fa-search text-4xl text-vroom-muted"></i>
      <h3 class="mt-4 text-xl font-semibold text-vroom-ink">No vehicles found</h3>
      <p class="mt-2 text-vroom-muted">We couldn't find any vehicles matching "<%= locals.searchcriteria || 'your search' %>"</p>
      <div class="mt-6 flex flex-wrap justify-center gap-3">
        <a href="/catalog" class="btn-primary"><i class="fas fa-car"></i> Browse All Vehicles</a>
        <a href="/" class="btn-secondary"><i class="fas fa-home"></i> Return Home</a>
      </div>
    </div>
  <% } %>
</section>
