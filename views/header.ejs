<nav class="sticky top-0 z-50 bg-white">
  <div class="relative mx-auto flex max-w-7xl items-center justify-between gap-4 px-4 py-4 sm:px-6 lg:px-8">
    <a href="/" class="shrink-0">
      <img src="/images/logo.png" alt="Vroom" class="h-7 w-auto sm:h-6">
    </a>

    <div class="flex items-center gap-2 sm:gap-3">
      <a href="/about" class="hidden rounded-full border border-vroom-line px-4 py-2 text-sm font-medium text-vroom-ink transition hover:bg-neutral-50 sm:inline-flex">
        Why choose Vroom
      </a>
      <a href="/help" class="hidden items-center gap-2 rounded-full bg-neutral-100 px-4 py-2 text-sm font-medium text-vroom-ink transition hover:bg-neutral-200 md:inline-flex">
        <i class="fas fa-circle-question text-vroom-accent"></i>
        Ask Vroom
      </a>
      <a href="/catalog/cart" class="relative flex h-10 w-10 items-center justify-center rounded-full border border-vroom-line text-vroom-ink transition hover:bg-neutral-50" aria-label="Cart">
        <i class="fa-solid fa-cart-shopping text-sm"></i>
        <span class="cart-count absolute -right-0.5 -top-0.5 flex h-4 min-w-4 items-center justify-center rounded-full bg-vroom-ink px-1 text-[10px] font-bold text-white">0</span>
      </a>

      <button class="mobile-menu-btn flex h-10 w-10 items-center justify-center rounded-full border border-vroom-line md:hidden" aria-label="Toggle menu">
        <span class="sr-only">Menu</span>
        <i class="fas fa-bars"></i>
      </button>

      <div class="hidden items-center gap-2 md:flex">
        <% if (session.customer_id > 0) { %>
          <div class="group relative">
            <button class="flex h-10 items-center gap-2 rounded-full border border-vroom-line pl-3 pr-1.5 text-sm font-medium transition hover:bg-neutral-50">
              <i class="fas fa-bars text-xs text-vroom-muted"></i>
              <span class="flex h-7 w-7 items-center justify-center rounded-full bg-vroom-ink text-xs font-semibold text-white">
                <%= (session.custname || 'U').charAt(0).toUpperCase() %>
              </span>
            </button>
            <div class="invisible absolute right-0 top-full z-50 mt-2 w-48 rounded-2xl border border-vroom-line bg-white py-2 opacity-0 shadow-xl transition group-hover:visible group-hover:opacity-100">
              <p class="px-4 py-2 text-xs text-vroom-muted">Signed in as <%= session.custname %></p>
              <a href="/customer/show" class="flex items-center gap-2 px-4 py-2 text-sm hover:bg-neutral-50"><i class="fas fa-user w-4"></i> Profile</a>
              <a href="/catalog" class="flex items-center gap-2 px-4 py-2 text-sm hover:bg-neutral-50"><i class="fas fa-car w-4"></i> Browse cars</a>
              <a href="/customer/logout" class="flex items-center gap-2 px-4 py-2 text-sm hover:bg-neutral-50"><i class="fas fa-sign-out-alt w-4"></i> Logout</a>
              <% if (session.admin) { %>
                <div class="my-2 border-t border-vroom-line"></div>
                <a href="/vehicle" class="flex items-center gap-2 px-4 py-2 text-sm hover:bg-neutral-50"><i class="fas fa-cog w-4"></i> Admin</a>
                <a href="/report" class="flex items-center gap-2 px-4 py-2 text-sm hover:bg-neutral-50"><i class="fas fa-chart-bar w-4"></i> Reports</a>
              <% } %>
            </div>
          </div>
        <% } else { %>
          <a href="/customer/login" class="flex h-10 items-center gap-2 rounded-full border border-vroom-line pl-3 pr-1.5 text-sm font-medium transition hover:bg-neutral-50">
            <i class="fas fa-bars text-xs text-vroom-muted"></i>
            <span class="flex h-7 w-7 items-center justify-center rounded-full bg-neutral-200 text-vroom-muted">
              <i class="fa-solid fa-user text-xs"></i>
            </span>
          </a>
        <% } %>
      </div>
    </div>
  </div>

  <div class="nav-menu hidden border-t border-vroom-line px-4 py-3 md:hidden">
    <a href="/about" class="block rounded-xl px-3 py-2 text-sm font-medium hover:bg-neutral-50">Why choose Vroom</a>
    <a href="/help" class="block rounded-xl px-3 py-2 text-sm font-medium hover:bg-neutral-50">Ask Vroom</a>
    <a href="/catalog" class="block rounded-xl px-3 py-2 text-sm font-medium hover:bg-neutral-50">Browse cars</a>
    <% if (session.customer_id > 0) { %>
      <a href="/customer/show" class="block rounded-xl px-3 py-2 text-sm font-medium hover:bg-neutral-50">Profile</a>
      <a href="/customer/logout" class="block rounded-xl px-3 py-2 text-sm font-medium hover:bg-neutral-50">Logout</a>
    <% } else { %>
      <a href="/customer/login" class="block rounded-xl px-3 py-2 text-sm font-medium hover:bg-neutral-50">Log in</a>
      <a href="/customer/register" class="block rounded-xl px-3 py-2 text-sm font-medium hover:bg-neutral-50">Sign up</a>
    <% } %>
  </div>
</nav>
