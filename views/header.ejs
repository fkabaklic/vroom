                                <a href="/vehicle"><i class="fas fa-car"></i> Vehicles</a>
                                <a href="/vehiclecat"><i class="fas fa-tags"></i> Categories</a>
                                <a href="/host"><i class="fas fa-user-tie"></i> Hosts</a>
                                <a href="/renter"><i class="fas fa-user"></i> Renters</a>
                                <a href="/saleorder"><i class="fas fa-file-invoice"></i> Orders</a>
