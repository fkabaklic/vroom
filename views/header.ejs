                <img src="/images/logo.png" alt="Vroom Logo" width="150" height="30">
            </a>
        </div>

        <div class="search-container">
            <form action="/search" method="get" class="search-form">
                <div class="search-input-wrapper">
                    <input type="text" name="searchcriteria" placeholder="Search cars, brands, or types..." value="<%= locals.searchcriteria || '' %>">
                    <button type="submit" class="search-btn">
                        <i class="fas fa-search"></i>
                    </button>
                </div>
                <div class="search-suggestions" id="searchSuggestions"></div>
            </form>
        </div>

        <button class="mobile-menu-btn" aria-label="Toggle menu">
            <span></span>
            <span></span>
            <span></span>
        </button>

        <div class="nav-menu">
            <ul class="nav-links">
                <li><a href="/">Home</a></li>
                <li><a href="/catalog">Cars</a></li>
                <li><a href="/catalog/cart" class="cart-link">
                    <i class="fa-solid fa-cart-shopping"></i>
                    <span class="cart-count">0</span>
                </a></li>
                <li class="user-menu">
                    <% if(session.customer_id > 0) { %>
                        <div class="user-dropdown">
                            <button class="user-btn">
                                <i class="fa-solid fa-user-large"></i>
                                <span><%= session.custname %></span>
                            </button>
                            <div class="user-dropdown-content">
                                <a href='/customer/show'><i class="fas fa-user"></i> Profile</a>
                                <a href='/customer/logout'><i class="fas fa-sign-out-alt"></i> Logout</a>
                            </div>
                        </div>
                    <% } else { %>
                        <a href='/customer/login' class="login-btn">
                            <i class="fa-solid fa-user-large"></i>
                           
                        </a>
                    <% } %>
