<nav class="sticky top-0 z-50 border-b border-vroom-line bg-white/95 backdrop-blur">
  <div class="relative mx-auto flex max-w-7xl items-center gap-4 px-4 py-3 sm:px-6 lg:px-8">
    <a href="/" class="shrink-0">
      <img src="/images/logo.png" alt="Vroom Logo" class="h-8 w-auto sm:h-9">
    </a>

    <form action="/search" method="get" class="hidden flex-1 md:block">
      <div class="relative mx-auto max-w-xl">
        <input
          type="text"
          name="searchcriteria"
          placeholder="Search cars, brands, or types..."
          value="<%= locals.searchcriteria || '' %>"
          class="w-full rounded-full border border-vroom-line bg-vroom-canvas py-2.5 pl-4 pr-12 text-sm outline-none transition focus:border-vroom-accent focus:bg-white focus:ring-2 focus:ring-blue-100"
        >
        <button type="submit" class="absolute right-1 top-1/2 flex h-9 w-9 -translate-y-1/2 items-center justify-center rounded-full bg-vroom-brand text-white transition hover:bg-slate-800">
          <i class="fas fa-search text-sm"></i>
        </button>
      </div>
    </form>

    <button class="mobile-menu-btn ml-auto flex h-10 w-10 flex-col items-center justify-center gap-1.5 rounded-lg border border-vroom-line md:hidden" aria-label="Toggle menu">
      <span class="h-0.5 w-5 rounded bg-vroom-ink transition"></span>
      <span class="h-0.5 w-5 rounded bg-vroom-ink transition"></span>
      <span class="h-0.5 w-5 rounded bg-vroom-ink transition"></span>
    </button>

    <div class="nav-menu relative hidden items-center gap-1 md:flex">
      <a href="/" class="rounded-lg px-3 py-2 text-sm font-medium text-vroom-ink transition hover:bg-slate-100">Home</a>
      <a href="/catalog" class="rounded-lg px-3 py-2 text-sm font-medium text-vroom-ink transition hover:bg-slate-100">Cars</a>
      <a href="/catalog/cart" class="relative rounded-lg px-3 py-2 text-sm font-medium text-vroom-ink transition hover:bg-slate-100">
        <i class="fa-solid fa-cart-shopping"></i>
        <span class="cart-count absolute -right-0.5 -top-0.5 flex h-4 min-w-4 items-center justify-center rounded-full bg-vroom-accent px-1 text-[10px] font-bold text-white">0</span>
      </a>

      <% if (session.customer_id > 0) { %>
        <div class="group relative">
          <button class="flex items-center gap-2 rounded-lg px-3 py-2 text-sm font-medium text-vroom-ink transition hover:bg-slate-100">
            <i class="fa-solid fa-user-large"></i>
            <span class="hidden lg:inline"><%= session.custname %></span>
          </button>
          <div class="invisible absolute right-0 top-full z-50 mt-2 w-44 rounded-xl border border-vroom-line bg-white py-2 opacity-0 shadow-lg transition group-hover:visible group-hover:opacity-100">
            <a href="/customer/show" class="flex items-center gap-2 px-4 py-2 text-sm text-vroom-ink hover:bg-slate-50"><i class="fas fa-user w-4"></i> Profile</a>
            <a href="/customer/logout" class="flex items-center gap-2 px-4 py-2 text-sm text-vroom-ink hover:bg-slate-50"><i class="fas fa-sign-out-alt w-4"></i> Logout</a>
          </div>
        </div>
      <% } else { %>
        <a href="/customer/login" class="rounded-lg px-3 py-2 text-sm font-medium text-vroom-ink transition hover:bg-slate-100">
          <i class="fa-solid fa-user-large"></i>
        </a>
      <% } %>

      <% if (session.admin) { %>
        <div class="group relative">
          <button class="flex items-center gap-2 rounded-lg bg-vroom-brand px-3 py-2 text-sm font-medium text-white transition hover:bg-slate-800">
            <i class="fas fa-cog"></i>
            <span class="hidden lg:inline">Admin</span>
          </button>
          <div class="invisible absolute right-0 top-full z-50 mt-2 w-52 rounded-xl border border-vroom-line bg-white py-2 opacity-0 shadow-lg transition group-hover:visible group-hover:opacity-100">
            <a href="/customer" class="flex items-center gap-2 px-4 py-2 text-sm hover:bg-slate-50"><i class="fas fa-users w-4"></i> Customers</a>
            <a href="/vehicle" class="flex items-center gap-2 px-4 py-2 text-sm hover:bg-slate-50"><i class="fas fa-car w-4"></i> Vehicles</a>
            <a href="/vehiclecat" class="flex items-center gap-2 px-4 py-2 text-sm hover:bg-slate-50"><i class="fas fa-tags w-4"></i> Categories</a>
            <a href="/host" class="flex items-center gap-2 px-4 py-2 text-sm hover:bg-slate-50"><i class="fas fa-user-tie w-4"></i> Hosts</a>
            <a href="/renter" class="flex items-center gap-2 px-4 py-2 text-sm hover:bg-slate-50"><i class="fas fa-user w-4"></i> Renters</a>
            <a href="/saleorder" class="flex items-center gap-2 px-4 py-2 text-sm hover:bg-slate-50"><i class="fas fa-file-invoice w-4"></i> Orders</a>
            <a href="/promotion" class="flex items-center gap-2 px-4 py-2 text-sm hover:bg-slate-50"><i class="fas fa-percent w-4"></i> Promotions</a>
            <a href="/report" class="flex items-center gap-2 px-4 py-2 text-sm hover:bg-slate-50"><i class="fas fa-chart-bar w-4"></i> Reports</a>
          </div>
        </div>
      <% } %>
    </div>
  </div>

  <form action="/search" method="get" class="border-t border-vroom-line px-4 py-3 md:hidden">
    <div class="relative">
      <input
        type="text"
        name="searchcriteria"
        placeholder="Search vehicles..."
        value="<%= locals.searchcriteria || '' %>"
        class="w-full rounded-full border border-vroom-line bg-vroom-canvas py-2.5 pl-4 pr-12 text-sm outline-none focus:border-vroom-accent focus:ring-2 focus:ring-blue-100"
      >
      <button type="submit" class="absolute right-1 top-1/2 flex h-9 w-9 -translate-y-1/2 items-center justify-center rounded-full bg-vroom-brand text-white">
        <i class="fas fa-search text-sm"></i>
      </button>
    </div>
  </form>
</nav>
