<section class="mx-auto max-w-7xl px-4 pt-6 sm:px-6 lg:px-8">
  <div class="grid min-h-[70vh] overflow-hidden rounded-[28px] border border-vroom-line lg:grid-cols-2">
    <div class="relative hidden min-h-[420px] lg:block">
      <img
        src="/images/vroom_hero_2.jpg"
        alt=""
        class="absolute inset-0 h-full w-full object-cover"
      >
      <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/35 to-black/15"></div>
      <div class="relative flex h-full flex-col justify-end p-10 text-white">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-white/70">Welcome back</p>
        <h1 class="mt-3 text-4xl font-bold tracking-tight">Sign in to Vroom</h1>
        <p class="mt-3 max-w-sm text-sm leading-relaxed text-white/85">
          Access your trips, saved bookings, and host tools in one place.
        </p>
      </div>
    </div>

    <div class="flex items-center bg-white px-6 py-12 sm:px-10 lg:px-12">
      <div class="mx-auto w-full max-w-md">
        <div class="lg:hidden">
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-vroom-muted">Account</p>
          <h1 class="mt-2 text-3xl font-bold tracking-tight text-vroom-ink">Sign in</h1>
          <p class="mt-2 text-sm text-vroom-muted">Use your Vroom username and password.</p>
        </div>

        <div class="hidden lg:block">
          <h2 class="text-2xl font-bold tracking-tight text-vroom-ink">Sign in</h2>
          <p class="mt-2 text-sm text-vroom-muted">Enter your credentials to continue.</p>
        </div>

        <% if (typeof message !== 'undefined' && message) { %>
          <div class="mt-6 rounded-2xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-900">
            <%= message %>
          </div>
        <% } %>

        <form action="/customer/login" method="post" class="mt-8 space-y-4">
          <div>
            <label for="username" class="mb-1.5 block text-sm font-medium text-vroom-ink">Username</label>
            <input
              type="text"
              id="username"
              name="username"
              placeholder="Your username"
              required
              autocomplete="username"
              class="w-full rounded-xl border border-vroom-line px-4 py-3 text-sm outline-none transition focus:border-vroom-ink focus:ring-2 focus:ring-neutral-200"
            >
          </div>

          <div>
            <label for="password" class="mb-1.5 block text-sm font-medium text-vroom-ink">Password</label>
            <input
              type="password"
              id="password"
              name="password"
              placeholder="Your password"
              required
              autocomplete="current-password"
              class="w-full rounded-xl border border-vroom-line px-4 py-3 text-sm outline-none transition focus:border-vroom-ink focus:ring-2 focus:ring-neutral-200"
            >
          </div>

          <button type="submit" class="btn-primary w-full py-3 text-base">
            Continue
          </button>
        </form>

        <div class="mt-8 border-t border-vroom-line pt-6">
          <p class="text-sm text-vroom-muted">New to Vroom?</p>
          <a href="/customer/register" class="btn-secondary mt-3 w-full">
            Create an account
          </a>
        </div>

        <p class="mt-6 text-center text-xs text-vroom-muted">
          By continuing, you agree to our
          <a href="/terms" class="underline hover:text-vroom-ink">Terms</a>
          and
          <a href="/privacy" class="underline hover:text-vroom-ink">Privacy Policy</a>.
        </p>
      </div>
    </div>
  </div>
</section>

<section class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
  <div class="flex flex-wrap items-center justify-center gap-3 text-sm text-vroom-muted">
    <a href="/help" class="hover:text-vroom-ink">Need help signing in?</a>
    <span class="hidden sm:inline">·</span>
    <a href="/contact" class="hover:text-vroom-ink">Contact support</a>
  </div>
</section>
