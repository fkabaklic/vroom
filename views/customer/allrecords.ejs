<% if (allrecs.length > 0) {%>
    <table>
        <tr>
            <th>Customer ID</th>
            <th>First Name</th>
            <th>Last Name</th>
            <th>Email</th>
            <th>Phone</th>
            <th>Address</th>
            <th>City</th>
            <th>State</th>
            <th>Zip</th>
            <th>Username</th>
            <th>Password</th>
            <th>Admin</th>
        </tr>
      <% allrecs.forEach((recref, index) => { %>
        <tr>
            <td><%= recref.customer_id %></td>
            <td><%= recref.firstname %></td>
            <td><%= recref.lastname %></td>
            <td><%= recref.email %></td>
            <td><%= recref.phone %></td>
            <td><%= recref.address %></td>
            <td><%= recref.city %></td>
            <td><%= recref.state %></td>
            <td><%= recref.zip %></td>
            <td><%= recref.username %></td>
            <td><%= recref.password %></td>
            <td><%= recref.admin %></td>
            
            <td><button class="btn3"><a href='/customer/<%= recref.customer_id %>/show'> Details</a></button></td>
            <td><button class="btn3"><a href='/customer/<%= recref.customer_id %>/edit'>Edit</a></button></td>
            <td><button class="btn3"><a href='/customer/<%= recref.customer_id %>/admin'>Make Admin</a></button></td>
            <td><button class="btn3"><a href='/customer/<%= recref.customer_id %>/removeadmin'>Remove Admin</a></button></td>
            <td><button class="btn3"><a href='/customer/<%= recref.customer_id %>/delete' onclick="return confirm('Are you sure you want to delete this record?');">Delete</a></button></td>
            </tr>
    <% }); %>
    </table>
    <% } else { %>
        <p>Not Records Available</p>
    <% } %>

    <div class="b">
        <button class="btn2"><a href='/customer/addrecord'><i class="fa-solid fa-plus"></i></a></button>
        </div>
