<!-- Customer Details Section -->
<section class="details-section">
    <div class="details-container">
        <div class="details-header">
            <h1><i class="fas fa-user"></i> Customer Details</h1>
            <p>View customer information and manage profile</p>
        </div>

        <div class="details-card">
            <div class="details-grid">
                <div class="detail-group">
                    <label>
                        <i class="fas fa-hashtag"></i> Customer ID
                    </label>
                    <span class="detail-value"><%= onerec.customer_id %></span>
                </div>

                <div class="detail-group">
                    <label>
                        <i class="fas fa-user"></i> First Name
                    </label>
                    <span class="detail-value"><%= onerec.firstname %></span>
                </div>

                <div class="detail-group">
                    <label>
                        <i class="fas fa-user"></i> Last Name
                    </label>
                    <span class="detail-value"><%= onerec.lastname %></span>
                </div>

                <div class="detail-group">
                    <label>
                        <i class="fas fa-envelope"></i> Email Address
                    </label>
                    <span class="detail-value"><%= onerec.email %></span>
                </div>

                <div class="detail-group">
                    <label>
                        <i class="fas fa-phone"></i> Phone Number
                    </label>
                    <span class="detail-value"><%= onerec.phone %></span>
                </div>

                <div class="detail-group full-width">
                    <label>
                        <i class="fas fa-map-marker-alt"></i> Address
                    </label>
                    <span class="detail-value"><%= onerec.address %></span>
                </div>

                <div class="detail-group">
                    <label>
                        <i class="fas fa-city"></i> City
                    </label>
                    <span class="detail-value"><%= onerec.city %></span>
                </div>

                <div class="detail-group">
                    <label>
                        <i class="fas fa-map"></i> State
                    </label>
                    <span class="detail-value"><%= onerec.state %></span>
                </div>

                <div class="detail-group">
                    <label>
                        <i class="fas fa-mail-bulk"></i> ZIP Code
                    </label>
                    <span class="detail-value"><%= onerec.zip %></span>
                </div>
            </div>

            <div class="details-actions">
                <a href="/customer/edit" class="btn btn-primary">
                    <i class="fas fa-edit"></i> Edit Profile
                </a>
                <a href="/customer/password" class="btn btn-secondary">
                    <i class="fas fa-lock"></i> Change Password
                </a>
                <a href="/customer" class="btn btn-secondary">
                    <i class="fas fa-arrow-left"></i> Back to List
                </a>
            </div>
        </div>
    </div>
</section>