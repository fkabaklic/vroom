<section class="mx-auto max-w-7xl px-4 pt-6 sm:px-6 lg:px-8">
  <div class="rounded-[28px] bg-neutral-50 px-6 py-10 sm:px-10">
    <p class="text-sm font-semibold uppercase tracking-[0.18em] text-vroom-muted">Account</p>
    <h1 class="mt-2 text-3xl font-bold tracking-tight text-vroom-ink sm:text-4xl">Create your account</h1>
    <p class="mt-2 max-w-xl text-sm text-vroom-muted">
      Join Vroom to book cars, manage trips, and save your details for faster checkout.
    </p>
  </div>
</section>

<section class="mx-auto max-w-3xl px-4 py-10 sm:px-6 lg:px-8">
  <div class="rounded-3xl border border-vroom-line bg-white p-6 shadow-sm sm:p-8">
    <form action="/customer" method="post" class="space-y-5">
      <div class="grid gap-4 sm:grid-cols-2">
        <div>
          <label for="firstname" class="mb-1.5 block text-sm font-medium text-vroom-ink">First name</label>
          <input type="text" id="firstname" name="firstname" required placeholder="First name" class="w-full rounded-xl border border-vroom-line px-4 py-3 text-sm outline-none focus:border-vroom-ink focus:ring-2 focus:ring-neutral-200">
        </div>
        <div>
          <label for="lastname" class="mb-1.5 block text-sm font-medium text-vroom-ink">Last name</label>
          <input type="text" id="lastname" name="lastname" required placeholder="Last name" class="w-full rounded-xl border border-vroom-line px-4 py-3 text-sm outline-none focus:border-vroom-ink focus:ring-2 focus:ring-neutral-200">
        </div>
      </div>

      <div class="grid gap-4 sm:grid-cols-2">
        <div>
          <label for="email" class="mb-1.5 block text-sm font-medium text-vroom-ink">Email</label>
          <input type="email" id="email" name="email" required placeholder="you@example.com" class="w-full rounded-xl border border-vroom-line px-4 py-3 text-sm outline-none focus:border-vroom-ink focus:ring-2 focus:ring-neutral-200">
        </div>
        <div>
          <label for="phone" class="mb-1.5 block text-sm font-medium text-vroom-ink">Phone</label>
          <input type="tel" id="phone" name="phone" required placeholder="Phone number" class="w-full rounded-xl border border-vroom-line px-4 py-3 text-sm outline-none focus:border-vroom-ink focus:ring-2 focus:ring-neutral-200">
        </div>
      </div>

      <div>
        <label for="address" class="mb-1.5 block text-sm font-medium text-vroom-ink">Address</label>
        <input type="text" id="address" name="address" required placeholder="Street address" class="w-full rounded-xl border border-vroom-line px-4 py-3 text-sm outline-none focus:border-vroom-ink focus:ring-2 focus:ring-neutral-200">
      </div>

      <div class="grid gap-4 sm:grid-cols-3">
        <div>
          <label for="city" class="mb-1.5 block text-sm font-medium text-vroom-ink">City</label>
          <input type="text" id="city" name="city" required placeholder="City" class="w-full rounded-xl border border-vroom-line px-4 py-3 text-sm outline-none focus:border-vroom-ink focus:ring-2 focus:ring-neutral-200">
        </div>
        <div>
          <label for="state" class="mb-1.5 block text-sm font-medium text-vroom-ink">State</label>
          <input type="text" id="state" name="state" required placeholder="State" class="w-full rounded-xl border border-vroom-line px-4 py-3 text-sm outline-none focus:border-vroom-ink focus:ring-2 focus:ring-neutral-200">
        </div>
        <div>
          <label for="zip" class="mb-1.5 block text-sm font-medium text-vroom-ink">ZIP</label>
          <input type="text" id="zip" name="zip" required placeholder="ZIP" class="w-full rounded-xl border border-vroom-line px-4 py-3 text-sm outline-none focus:border-vroom-ink focus:ring-2 focus:ring-neutral-200">
        </div>
      </div>

      <div class="grid gap-4 border-t border-vroom-line pt-5 sm:grid-cols-2">
        <div>
          <label for="username" class="mb-1.5 block text-sm font-medium text-vroom-ink">Username</label>
          <input type="text" id="username" name="username" required placeholder="Choose a username" class="w-full rounded-xl border border-vroom-line px-4 py-3 text-sm outline-none focus:border-vroom-ink focus:ring-2 focus:ring-neutral-200">
        </div>
        <div>
          <label for="password" class="mb-1.5 block text-sm font-medium text-vroom-ink">Password</label>
          <input type="password" id="password" name="password" required placeholder="Create a password" class="w-full rounded-xl border border-vroom-line px-4 py-3 text-sm outline-none focus:border-vroom-ink focus:ring-2 focus:ring-neutral-200">
        </div>
      </div>

      <div class="flex flex-wrap gap-3 pt-2">
        <button type="submit" class="btn-primary">Create account</button>
        <a href="/customer/login" class="btn-secondary">Already have an account?</a>
      </div>
    </form>
  </div>
</section>
