<% if (allrecs.length > 0) {%>
    <table>
        <tr>
            <th>Renter ID</th>
            <th>Name</th>
            <th>Vehicle Type</th>
            <th>Status</th>
        </tr>
      <% allrecs.forEach((recref, index) => { %>
        <tr>
            <td><%= recref.renter_id %></td>
            <td><%= recref.name %></td>
            <td><%= recref.vehicle_type %></td>
            <td><%= recref.status %></td>
            <td><button class="btn3"><a href='/renter/<%= recref.renter_id %>/show'> Details</a></button></td>
            <td><button class="btn3"><a href='/renter/<%= recref.renter_id %>/edit'>Edit</a></button></td>
            <td><button class="btn3"><a href='/renter/<%= recref.renter_id %>/delete' onclick="return confirm('Are you sure you want to delete this record?');">Delete</a></button></td>
            </tr>
    <% }); %>
    </table>
    <% } else { %>
        <p>Not Records Available</p>
    <% } %>

    <div class="b">
        <button class="btn2"><a href='/renter/addrecord'><i class="fa-solid fa-plus"></i></a></button>
        </div>
