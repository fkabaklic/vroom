<h1> Edit Customer</h1>
<form action="/renter/save" method="post">
   <input type="hidden" name="renter_id" value="<%= onerec.renter_id %>" >
<table>
	<tr> <td> Name: </td> <td> <input type="text" name="name" value="<%= onerec.name %>"required>  </td> </tr>
	<tr> <td> Vehicle Type: </td> <td><input type="text" name="vehicle_type" value="<%= onerec.vehicle_type %>"required>  </td> </tr>
	<tr> <td> Status: </td> <td> <input type="text" name="status" value="<%= onerec.status %>" required>  </td> </tr>
</table>
<button class="rec" type="submit">Save</button>
</form>
