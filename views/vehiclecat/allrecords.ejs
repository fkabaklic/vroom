<% if (allrecs.length > 0) {%>
    <table>
        <tr>
            <th>Vehicle Category ID</th>
            <th>Vehicle Make</th>
            <th>Vehicle Model</th>
            <th>Vehicle Type</th>
        </tr>
      <% allrecs.forEach((recref, index) => { %>
        <tr>
            <td><%= recref.vehiclecat_id %></td>
            <td><%= recref.vehicle_make %></td>
            <td><%= recref.vehicle_model %></td>
            <td><%= recref.vehicle_type %></td>
            <td><button class="btn3"><a href='/vehiclecat/<%= recref.vehiclecat_id %>/show'> Details</a></button></td>
            <td><button class="btn3"><a href='/vehiclecat/<%= recref.vehiclecat_id %>/edit'>Edit</a></button></td>
            <td><button class="btn3"><a href='/vehiclecat/<%= recref.vehiclecat_id %>/delete' onclick="return confirm('Are you sure you want to delete this record?');">Delete</a></button></td>
            </tr>
    <% }); %>
    </table>
    <% } else { %>
        <p>Not Records Available</p>
    <% } %>

    <div class="b">
        <button class="btn2"><a href='/vehiclecat/addrecord'><i class="fa-solid fa-plus"></i></a></button>
        </div>
