<!-- Add Vehicle Category Record Section -->
<section class="form-section">
    <div class="form-container">
        <div class="form-header">
            <h1><i class="fas fa-tags"></i> Add New Vehicle Category</h1>
            <p>Enter the vehicle category information below</p>
        </div>

        <form action="/vehiclecat" method="post" class="modern-form">
            <div class="form-grid">
                <div class="form-group">
                    <label for="vehiclecat_id">
                        <i class="fas fa-hashtag"></i> Vehicle Category ID
                    </label>
                    <input type="text" id="vehiclecat_id" name="vehiclecat_id" required placeholder="Enter category ID">
                </div>

                <div class="form-group">
                    <label for="vehicle_make">
                        <i class="fas fa-car"></i> Vehicle Make
                    </label>
                    <input type="text" id="vehicle_make" name="vehicle_make" required placeholder="Enter vehicle make">
                </div>

                <div class="form-group">
                    <label for="vehicle_model">
                        <i class="fas fa-car-side"></i> Vehicle Model
                    </label>
                    <input type="text" id="vehicle_model" name="vehicle_model" required placeholder="Enter vehicle model">
                </div>

                <div class="form-group">
                    <label for="vehicle_type">
                        <i class="fas fa-tag"></i> Vehicle Type
                    </label>
                    <select id="vehicle_type" name="vehicle_type" required>
                        <option value="" disabled selected>Select vehicle type</option>
                        <option value="Sedan">Sedan</option>
                        <option value="SUV">SUV</option>
                        <option value="Truck">Truck</option>
                        <option value="Sports Car">Sports Car</option>
                        <option value="Luxury">Luxury</option>
                        <option value="Electric">Electric</option>
                        <option value="Hybrid">Hybrid</option>
                        <option value="Compact">Compact</option>
                        <option value="Van">Van</option>
                        <option value="Motorcycle">Motorcycle</option>
                    </select>
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save"></i> Save Category
                </button>
                <a href="/vehiclecat" class="btn btn-secondary">
                    <i class="fas fa-arrow-left"></i> Back to List
                </a>
            </div>
        </form>
    </div>
</section>

