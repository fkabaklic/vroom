<section class="mx-auto max-w-7xl px-4 pt-6 sm:px-6 lg:px-8">
  <div class="rounded-[28px] bg-neutral-50 px-6 py-14 text-center sm:px-10">
    <p class="text-sm font-semibold uppercase tracking-[0.18em] text-vroom-muted">Support</p>
    <h1 class="mt-3 text-3xl font-bold tracking-tight text-vroom-ink sm:text-4xl">Help Center</h1>
    <p class="mx-auto mt-3 max-w-xl text-sm text-vroom-muted sm:text-base">
      Find answers about booking, payments, cancellations, and hosting — or reach out if you need a hand.
    </p>
    <form action="/search" method="get" class="mx-auto mt-8 flex max-w-xl items-center gap-2 rounded-full border border-vroom-line bg-white p-2 shadow-sm">
      <input
        type="text"
        name="searchcriteria"
        placeholder="Search cars or topics..."
        class="min-w-0 flex-1 border-0 bg-transparent px-4 py-2 text-sm outline-none"
