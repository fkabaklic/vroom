      <button type="submit" class="flex h-10 w-10 items-center justify-center rounded-full bg-vroom-accent text-white" aria-label="Search">
        <i class="fas fa-search text-sm"></i>
      </button>
    </form>
  </div>
</section>

<section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
    <a href="#booking" class="rounded-3xl border border-vroom-line bg-white p-5 transition hover:border-vroom-ink/20 hover:shadow-sm">
      <div class="flex h-10 w-10 items-center justify-center rounded-2xl bg-neutral-100 text-vroom-accent"><i class="fas fa-calendar-check"></i></div>
      <h2 class="mt-4 font-semibold text-vroom-ink">Booking</h2>
      <p class="mt-1 text-sm text-vroom-muted">Reserve a car and manage trips</p>
    </a>
    <a href="#payments" class="rounded-3xl border border-vroom-line bg-white p-5 transition hover:border-vroom-ink/20 hover:shadow-sm">
      <div class="flex h-10 w-10 items-center justify-center rounded-2xl bg-neutral-100 text-vroom-accent"><i class="fas fa-credit-card"></i></div>
      <h2 class="mt-4 font-semibold text-vroom-ink">Payments</h2>
      <p class="mt-1 text-sm text-vroom-muted">Pricing, taxes, and receipts</p>
    </a>
    <a href="#cancellations" class="rounded-3xl border border-vroom-line bg-white p-5 transition hover:border-vroom-ink/20 hover:shadow-sm">
      <div class="flex h-10 w-10 items-center justify-center rounded-2xl bg-neutral-100 text-vroom-accent"><i class="fas fa-rotate-left"></i></div>
      <h2 class="mt-4 font-semibold text-vroom-ink">Cancellations</h2>
      <p class="mt-1 text-sm text-vroom-muted">Refunds and trip changes</p>
    </a>
    <a href="#hosting" class="rounded-3xl border border-vroom-line bg-white p-5 transition hover:border-vroom-ink/20 hover:shadow-sm">
      <div class="flex h-10 w-10 items-center justify-center rounded-2xl bg-neutral-100 text-vroom-accent"><i class="fas fa-key"></i></div>
      <h2 class="mt-4 font-semibold text-vroom-ink">Hosting</h2>
      <p class="mt-1 text-sm text-vroom-muted">List your vehicle on Vroom</p>
    </a>
