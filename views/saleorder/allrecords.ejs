<% if (allrecs.length > 0) {%>
    <table>
        <tr>
            <th>Sale Order ID</th>
            <th>Sale Date</th>
            <th>Customer ID</th>
            <th>Vehicle ID</th>
            <th>Sale Price</th>
        </tr>
        
      <% allrecs.forEach((recref, index) => { %>
        <tr>
            <td><%= recref.saleorder_id %></td>
            <td><%= recref.saledate.toLocaleDateString('en-US') %></td>
            <td><%= recref.customer_id %></td>
            <td><%= recref.vehicle_id %></td>
            <td><%= Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format (recref.saleprice) %></td>
            <td><button class="btn3"><a href='/saleorder/<%= recref.saleorder_id %>/show'> Details</a></button></td>
            <td><button class="btn3"><a href='/saleorder/<%= recref.saleorder_id %>/edit'>Edit</a></button></td>
            <td><button class="btn3"><a href='/saleorder/<%= recref.saleorder_id %>/delete' onclick="return confirm('Are you sure you want to delete this record?');">Delete</a></button></td>
            </tr>
    <% }); %>
    </table>
    <% } else { %>
        <p>Not Records Available</p>
    <% } %>

    <div class="b">
        <button class="btn2"><a href='/saleorder/addrecord'><i class="fa-solid fa-plus"></i></a></button>
        </div>
