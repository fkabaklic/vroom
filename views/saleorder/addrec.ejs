<!-- Add Sale Order Record Section -->
<section class="form-section">
    <div class="form-container">
        <div class="form-header">
            <h1><i class="fas fa-file-invoice"></i> Add New Sale Order</h1>
            <p>Enter the sale order information below</p>
        </div>

        <form action="/saleorder" method="post" class="modern-form">
            <div class="form-grid">
                <div class="form-group">
                    <label for="saleorder_id">
                        <i class="fas fa-hashtag"></i> Order ID
                    </label>
                    <input type="text" id="saleorder_id" name="saleorder_id" required placeholder="Enter order ID">
                </div>

                <div class="form-group">
                    <label for="saledate">
                        <i class="fas fa-calendar"></i> Sale Date
                    </label>
                    <input type="date" id="saledate" name="saledate" required>
                </div>

                <div class="form-group">
                    <label for="host_id">
                        <i class="fas fa-user-tie"></i> Host ID
                    </label>
                    <input type="number" id="host_id" name="host_id" required placeholder="Enter host ID">
                </div>

                <div class="form-group">
                    <label for="customer_id">
                        <i class="fas fa-user"></i> Customer ID
                    </label>
                    <input type="number" id="customer_id" name="customer_id" required placeholder="Enter customer ID">
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save"></i> Save Order
                </button>
                <a href="/saleorder" class="btn btn-secondary">
                    <i class="fas fa-arrow-left"></i> Back to List
                </a>
            </div>
        </form>
    </div>
</section>

