<h1> Edit Customer</h1>
<form action="/saleorder/save" method="post">
   <input type="hidden" name="saleorder_id" value="<%= onerec.saleorder_id %>" >
<table>
	<tr> <td> Sale Date: </td> <td> <input type="date" name="saledate" value="<%= onerec.saledate.toISOString().split('T')[0] %>"required>  </td> </tr>
	<tr> <td> Customer ID: </td> <td> <input type="text" name="customer_id" value="<%= onerec.customer_id %>" required>  </td> </tr>
	<tr> <td> Vehicle ID: </td> <td><input type="text" name="vehicle_id" value="<%= onerec.vehicle_id %>"required>  </td> </tr>
	<tr> <td> Sale Price: </td> <td><input type="text" name="saleprice" value="<%= onerec.saleprice %>"required>  </td> </tr>
</table>
<button class="rec" type="submit">Save</button>
</form>
