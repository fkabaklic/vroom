<section class="border-b border-vroom-line bg-white">
  <div class="mx-auto max-w-4xl px-4 py-14 text-center sm:px-6 lg:px-8">
    <h1 class="text-3xl font-bold text-vroom-ink sm:text-4xl">Contact Us</h1>
    <p class="mx-auto mt-3 max-w-xl text-vroom-muted">
      Have a question about a rental, your booking, or becoming a host? We'd love to hear from you.
    </p>
  </div>
</section>

<section class="mx-auto max-w-5xl px-4 py-12 sm:px-6 lg:px-8">
  <div class="grid gap-5 sm:grid-cols-3">
    <div class="flex items-start gap-4 rounded-2xl border border-vroom-line bg-white p-5 shadow-sm">
      <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-blue-50 text-vroom-accent">
        <i class="fas fa-phone"></i>
      </div>
      <div>
        <h3 class="font-semibold text-vroom-ink">Phone</h3>
        <p class="mt-1 text-sm text-vroom-muted">+1 (555) 123-4567</p>
        <p class="text-xs text-vroom-muted">Mon-Fri, 8 AM - 6 PM CT</p>
      </div>
    </div>

    <div class="flex items-start gap-4 rounded-2xl border border-vroom-line bg-white p-5 shadow-sm">
      <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-blue-50 text-vroom-accent">
        <i class="fas fa-envelope"></i>
      </div>
      <div>
        <h3 class="font-semibold text-vroom-ink">Email</h3>
        <p class="mt-1 text-sm text-vroom-muted">support@vroom.com</p>
        <p class="text-xs text-vroom-muted">General inquiries and booking help</p>
      </div>
    </div>

    <div class="flex items-start gap-4 rounded-2xl border border-vroom-line bg-white p-5 shadow-sm sm:col-span-3 lg:col-span-1">
      <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-blue-50 text-vroom-accent">
        <i class="fas fa-map-marker-alt"></i>
      </div>
      <div>
        <h3 class="font-semibold text-vroom-ink">Office</h3>
        <p class="mt-1 text-sm text-vroom-muted">1 E Jackson Blvd, Suite 8000</p>
        <p class="text-sm text-vroom-muted">Chicago, IL 60604</p>
      </div>
    </div>
  </div>

  <div class="mt-10 grid gap-10 lg:grid-cols-2 lg:items-start">
    <div class="rounded-2xl border border-vroom-line bg-white p-6 shadow-sm sm:p-8">
      <h2 class="text-xl font-bold text-vroom-ink">Send Us a Message</h2>
      <p class="mt-2 text-sm text-vroom-muted">Fill out the form and we'll get back to you within one business day.</p>

      <% if (typeof success !== 'undefined' && success) { %>
        <div class="mt-6 rounded-xl border border-green-200 bg-green-50 px-4 py-4 text-sm text-green-700">
          <p class="font-medium"><i class="fas fa-check-circle"></i> Message sent!</p>
          <p class="mt-1">Thanks for reaching out. Our team will reply shortly.</p>
        </div>
      <% } else { %>
        <form action="/contact" method="post" class="mt-6 space-y-4">
          <div>
            <label for="name" class="mb-1.5 block text-sm font-medium text-vroom-ink">Full Name</label>
            <input type="text" id="name" name="name" placeholder="Your name" required class="w-full rounded-xl border border-vroom-line bg-vroom-canvas px-4 py-3 text-sm outline-none transition focus:border-vroom-accent focus:bg-white focus:ring-2 focus:ring-blue-100">
          </div>

          <div>
            <label for="email" class="mb-1.5 block text-sm font-medium text-vroom-ink">Email Address</label>
            <input type="email" id="email" name="email" placeholder="you@example.com" required class="w-full rounded-xl border border-vroom-line bg-vroom-canvas px-4 py-3 text-sm outline-none transition focus:border-vroom-accent focus:bg-white focus:ring-2 focus:ring-blue-100">
          </div>

          <div>
            <label for="subject" class="mb-1.5 block text-sm font-medium text-vroom-ink">Subject</label>
            <select id="subject" name="subject" required class="w-full rounded-xl border border-vroom-line bg-vroom-canvas px-4 py-3 text-sm outline-none transition focus:border-vroom-accent focus:bg-white focus:ring-2 focus:ring-blue-100">
              <option value="" disabled selected>Select a topic</option>
              <option value="booking">Booking and Reservations</option>
              <option value="billing">Billing and Payments</option>
              <option value="hosting">Become a Host</option>
              <option value="other">Other</option>
            </select>
          </div>

          <div>
            <label for="message" class="mb-1.5 block text-sm font-medium text-vroom-ink">Message</label>
            <textarea id="message" name="message" rows="5" placeholder="How can we help?" required class="w-full resize-y rounded-xl border border-vroom-line bg-vroom-canvas px-4 py-3 text-sm outline-none transition focus:border-vroom-accent focus:bg-white focus:ring-2 focus:ring-blue-100"></textarea>
          </div>

          <button type="submit" class="btn-primary btn-block">
            <i class="fas fa-paper-plane"></i> Send Message
          </button>
        </form>
      <% } %>
    </div>

    <div class="space-y-6">
      <div class="rounded-2xl border border-vroom-line bg-vroom-canvas p-6">
        <h2 class="text-xl font-bold text-vroom-ink">Get in Touch</h2>
        <p class="mt-3 text-sm leading-relaxed text-vroom-muted">
          Our support team is available Monday through Friday, 8 AM to 6 PM CT.
          Whether you need help with a booking, have a billing question, or want to
          learn about listing your vehicle, we're here to help.
        </p>
      </div>

      <div class="rounded-2xl border border-vroom-line bg-white p-6 shadow-sm">
        <h3 class="font-semibold text-vroom-ink">Common Questions</h3>
        <dl class="mt-4 space-y-4 text-sm">
          <div>
            <dt class="font-medium text-vroom-ink">How do I cancel a booking?</dt>
            <dd class="mt-1 text-vroom-muted">Log in, go to your profile, and view your order history. Cancellations made 24+ hours before pickup are fully refunded.</dd>
          </div>
          <div>
            <dt class="font-medium text-vroom-ink">What do I need to rent?</dt>
            <dd class="mt-1 text-vroom-muted">A valid driver's license, a credit card, and an active Vroom account.</dd>
          </div>
          <div>
            <dt class="font-medium text-vroom-ink">Can I list my car?</dt>
            <dd class="mt-1 text-vroom-muted">Yes. Visit our <a href="/help" class="font-medium text-vroom-accent underline">Help Center</a> to learn about becoming a host.</dd>
          </div>
        </dl>
      </div>
    </div>
  </div>
</section>
