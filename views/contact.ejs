<section class="mx-auto max-w-7xl px-4 pt-6 sm:px-6 lg:px-8">
  <div class="rounded-[28px] bg-neutral-50 px-6 py-14 text-center sm:px-10">
    <p class="text-sm font-semibold uppercase tracking-[0.18em] text-vroom-muted">Support</p>
    <h1 class="mt-3 text-3xl font-bold tracking-tight text-vroom-ink sm:text-4xl">Contact us</h1>
    <p class="mx-auto mt-3 max-w-xl text-sm text-vroom-muted sm:text-base">
      Questions about a rental, booking, or becoming a host? We're here to help.
    </p>
  </div>
</section>

<section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
  <div class="grid gap-4 sm:grid-cols-3">
    <div class="rounded-3xl border border-vroom-line bg-white p-5">
      <div class="flex h-10 w-10 items-center justify-center rounded-2xl bg-neutral-100 text-vroom-accent"><i class="fas fa-phone"></i></div>
      <h3 class="mt-4 font-semibold text-vroom-ink">Phone</h3>
      <p class="mt-1 text-sm text-vroom-muted">+1 (555) 123-4567</p>
      <p class="text-xs text-vroom-muted">Mon–Fri, 8 AM – 6 PM CT</p>
    </div>
    <div class="rounded-3xl border border-vroom-line bg-white p-5">
      <div class="flex h-10 w-10 items-center justify-center rounded-2xl bg-neutral-100 text-vroom-accent"><i class="fas fa-envelope"></i></div>
      <h3 class="mt-4 font-semibold text-vroom-ink">Email</h3>
      <p class="mt-1 text-sm text-vroom-muted">support@vroom.com</p>
      <p class="text-xs text-vroom-muted">General inquiries and booking help</p>
    </div>
    <div class="rounded-3xl border border-vroom-line bg-white p-5">
      <div class="flex h-10 w-10 items-center justify-center rounded-2xl bg-neutral-100 text-vroom-accent"><i class="fas fa-map-marker-alt"></i></div>
      <h3 class="mt-4 font-semibold text-vroom-ink">Office</h3>
      <p class="mt-1 text-sm text-vroom-muted">1 E Jackson Blvd, Suite 8000</p>
      <p class="text-sm text-vroom-muted">Chicago, IL 60604</p>
    </div>
  </div>

  <div class="mt-10 grid gap-8 lg:grid-cols-2 lg:items-start">
    <div class="rounded-3xl border border-vroom-line bg-white p-6 shadow-sm sm:p-8">
      <h2 class="text-xl font-bold text-vroom-ink">Send a message</h2>
      <p class="mt-2 text-sm text-vroom-muted">We'll get back to you within one business day.</p>

      <% if (typeof success !== 'undefined' && success) { %>
        <div class="mt-6 rounded-2xl border border-emerald-200 bg-emerald-50 px-4 py-4 text-sm text-emerald-800">
          <p class="font-medium"><i class="fas fa-check-circle"></i> Message sent</p>
          <p class="mt-1">Thanks for reaching out. Our team will reply shortly.</p>
        </div>
      <% } else { %>
        <form action="/contact" method="post" class="mt-6 space-y-4">
          <div>
            <label for="name" class="mb-1.5 block text-sm font-medium text-vroom-ink">Full name</label>
            <input type="text" id="name" name="name" placeholder="Your name" required class="w-full rounded-xl border border-vroom-line px-4 py-3 text-sm outline-none focus:border-vroom-ink focus:ring-2 focus:ring-neutral-200">
          </div>
          <div>
            <label for="email" class="mb-1.5 block text-sm font-medium text-vroom-ink">Email</label>
            <input type="email" id="email" name="email" placeholder="you@example.com" required class="w-full rounded-xl border border-vroom-line px-4 py-3 text-sm outline-none focus:border-vroom-ink focus:ring-2 focus:ring-neutral-200">
          </div>
          <div>
            <label for="subject" class="mb-1.5 block text-sm font-medium text-vroom-ink">Subject</label>
            <select id="subject" name="subject" required class="w-full rounded-xl border border-vroom-line px-4 py-3 text-sm outline-none focus:border-vroom-ink focus:ring-2 focus:ring-neutral-200">
              <option value="" disabled selected>Select a topic</option>
              <option value="booking">Booking and reservations</option>
              <option value="billing">Billing and payments</option>
              <option value="hosting">Become a host</option>
              <option value="other">Other</option>
            </select>
          </div>
          <div>
            <label for="message" class="mb-1.5 block text-sm font-medium text-vroom-ink">Message</label>
            <textarea id="message" name="message" rows="5" placeholder="How can we help?" required class="w-full resize-y rounded-xl border border-vroom-line px-4 py-3 text-sm outline-none focus:border-vroom-ink focus:ring-2 focus:ring-neutral-200"></textarea>
          </div>
          <button type="submit" class="btn-primary w-full"><i class="fas fa-paper-plane"></i> Send message</button>
        </form>
      <% } %>
    </div>

    <div class="space-y-6">
      <div class="rounded-3xl border border-vroom-line bg-white p-6">
        <h2 class="text-lg font-semibold text-vroom-ink">Common questions</h2>
        <dl class="mt-4 space-y-4 text-sm">
          <div>
            <dt class="font-medium text-vroom-ink">How do I cancel a booking?</dt>
            <dd class="mt-1 text-vroom-muted">Log in, open your profile, and review your orders. Cancellations 24+ hours before pickup are typically fully refunded.</dd>
          </div>
          <div>
            <dt class="font-medium text-vroom-ink">What do I need to rent?</dt>
            <dd class="mt-1 text-vroom-muted">A valid driver's license, a payment method, and an active Vroom account.</dd>
          </div>
          <div>
            <dt class="font-medium text-vroom-ink">Can I list my car?</dt>
            <dd class="mt-1 text-vroom-muted">Yes. Visit the <a href="/help" class="font-medium text-vroom-accent underline">Help Center</a> or send us a message about hosting.</dd>
          </div>
        </dl>
      </div>
      <div class="rounded-3xl bg-vroom-ink p-6 text-white">
        <h3 class="font-semibold">Prefer self-serve?</h3>
        <p class="mt-2 text-sm text-white/70">Browse FAQs in the Help Center anytime.</p>
        <a href="/help" class="btn-primary mt-4 bg-white text-vroom-ink hover:bg-neutral-100">Open Help Center</a>
      </div>
    </div>
  </div>
</section>
